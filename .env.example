# ─── 뉴스 API ───
# GNews (https://gnews.io) — 무료 100req/day
GNEWS_API_KEY=

# NewsAPI (https://newsapi.org) — 무료 100req/day (dev only)
# GNews 대신 쓸 경우에만 설정
NEWSAPI_KEY=

# ─── 시장 데이터 (선택 — MVP는 없어도 됨) ───
# Finnhub (https://finnhub.io) — 무료 60req/min
# 시장 뉴스 보강용. 없으면 GNews만으로 파이프라인 동작.
FINNHUB_API_KEY=

# ─── AI ───
# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# ─── DB ───
# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── 캐시 (선택) ───
# Cloudflare Workers KV — 없으면 인메모리 캐시 사용
# CF_KV_NAMESPACE_ID=
# CF_KV_API_TOKEN=

# ─── Cron 보안 ───
CRON_SECRET=change-me-to-random-string
